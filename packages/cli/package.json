{
  "name": "@llm-guardrails/cli",
  "version": "0.1.0",
  "description": "Interactive CLI tool for testing and demonstrating LLM guardrails",
  "keywords": [
    "cli",
    "guardrails",
    "llm",
    "testing",
    "security",
    "interactive"
  ],
  "author": "LLM Guardrails Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/llm-guardrails/llm-guardrails.git",
    "directory": "packages/cli"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "llm-guardrails": "./dist/cli.js",
    "guardrails": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/cli.ts src/index.ts --format cjs --dts",
    "dev": "tsup src/cli.ts src/index.ts --format cjs --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@llm-guardrails/core": "workspace:*",
    "chalk": "^4.1.2",
    "commander": "^12.0.0",
    "inquirer": "^8.2.6",
    "ora": "^5.4.1",
    "table": "^6.8.2"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
