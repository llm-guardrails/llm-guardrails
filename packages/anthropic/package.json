{
  "name": "@llm-guardrails/anthropic",
  "version": "0.1.0",
  "description": "Anthropic SDK integration with LLM guardrails - drop-in replacement for Claude API with built-in safety",
  "keywords": [
    "anthropic",
    "claude",
    "guardrails",
    "llm",
    "safety",
    "moderation",
    "content-filtering",
    "ai-safety"
  ],
  "author": "LLM Guardrails Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/llm-guardrails/llm-guardrails.git",
    "directory": "packages/anthropic"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "@llm-guardrails/core": "^0.1.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@llm-guardrails/core": "workspace:*",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
