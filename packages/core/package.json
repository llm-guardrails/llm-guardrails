{
  "name": "@llm-guardrails/core",
  "version": "0.1.7",
  "description": "TypeScript-native LLM guardrails with behavioral analysis and budget controls. Zero runtime dependencies. 100% test pass rate.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "llm",
    "guardrails",
    "security",
    "ai-safety",
    "typescript",
    "prompt-injection",
    "pii",
    "behavioral-analysis",
    "budget-control",
    "content-moderation",
    "toxicity-detection",
    "openai",
    "anthropic",
    "claude",
    "gpt",
    "gemini"
  ],
  "author": "LLM Guardrails Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/llm-guardrails/llm-guardrails.git"
  },
  "bugs": {
    "url": "https://github.com/llm-guardrails/llm-guardrails/issues"
  },
  "homepage": "https://github.com/llm-guardrails/llm-guardrails#readme",
  "peerDependencies": {
    "better-sqlite3": "^9.0.0",
    "ioredis": "^5.0.0",
    "@anthropic-ai/sdk": "^0.20.0",
    "openai": "^4.0.0",
    "@google-cloud/vertexai": "^1.0.0",
    "@aws-sdk/client-bedrock-runtime": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    },
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "openai": {
      "optional": true
    },
    "@google-cloud/vertexai": {
      "optional": true
    },
    "@aws-sdk/client-bedrock-runtime": {
      "optional": true
    }
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vitest/coverage-v8": "^1.2.0",
    "@vitest/ui": "^1.2.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.4",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
