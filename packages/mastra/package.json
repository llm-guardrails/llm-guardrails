{
  "name": "@llm-guardrails/mastra",
  "version": "0.2.0",
  "description": "Mastra integration for LLM Guardrails - Add guardrails to Mastra agents and LLMs",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mastra",
    "guardrails",
    "llm",
    "ai-safety",
    "agents",
    "typescript",
    "decorator"
  ],
  "author": "LLM Guardrails Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/llm-guardrails/llm-guardrails.git",
    "directory": "packages/mastra"
  },
  "bugs": {
    "url": "https://github.com/llm-guardrails/llm-guardrails/issues"
  },
  "homepage": "https://github.com/llm-guardrails/llm-guardrails#readme",
  "peerDependencies": {
    "@mastra/core": ">=0.1.0",
    "@llm-guardrails/core": "^0.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
